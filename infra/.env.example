POSTGRES_PASSWORD=change_me
MINIO_ROOT_PASSWORD=change_me
MINIO_SECRET_ACCESS_KEY=change_me
GF_SECURITY_ADMIN_PASSWORD=change_me
DOCUMINT_JWT_SECRET=change_me_use_openssl_rand_hex_32
DOCUMINT_JWT_ALGORITHM=HS256
DOCUMINT_JWT_AUDIENCE=documint-api
DOCUMINT_DEV_MODE=false
DOCUMINT_VERIFIER_PIL_FALLBACK=false
DOCUMINT_LAYOUT_BACKEND=docling
DOCUMINT_EXTRACTION_BACKEND=anthropic
ANTHROPIC_API_KEY=
DOCUMINT_EXTRACTION_ENDPOINT=http://localhost:11434/v1
